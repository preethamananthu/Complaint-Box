rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection: store user roles
    match /users/{userId} {
      allow create: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null;
      allow update: if request.auth != null && (
        // user can update own profile but cannot change role
        (request.auth.uid == userId && request.resource.data.role == resource.data.role)
        // admin can update any user's role
        || (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
      allow delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Complaints collection
    match /complaints/{complaintId} {
      allow create: if request.auth != null && request.resource.data.authorId == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.description is string
        && request.resource.data.isDeleted == false;

      allow read: if request.auth != null;

      allow update: if request.auth != null && (
        (
          // author can edit only while open, and can soft-delete anytime if not already deleted
          request.auth.uid == resource.data.authorId
          && resource.data.isDeleted != true
          && (
            resource.data.status == 'open'
            || request.resource.data.isDeleted == true
          )
        )
        || (
          // admin can edit only while open, and can soft-delete anytime if not already deleted
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
          && resource.data.isDeleted != true
          && (
            resource.data.status == 'open'
            || request.resource.data.isDeleted == true
          )
        )
      );

      // Physical deletes are disabled; use soft-delete (isDeleted = true).
      allow delete: if false;

      // Comments subcollection
      match /comments/{commentId} {
        allow create: if request.auth != null && request.resource.data.authorId == request.auth.uid
          && request.resource.data.text is string
          && get(/databases/$(database)/documents/complaints/$(complaintId)).data.status == 'open'
          && get(/databases/$(database)/documents/complaints/$(complaintId)).data.isDeleted != true;
        allow read: if request.auth != null;
        allow update: if request.auth != null
          && request.resource.data.text is string
          && get(/databases/$(database)/documents/complaints/$(complaintId)).data.status == 'open'
          && get(/databases/$(database)/documents/complaints/$(complaintId)).data.isDeleted != true
          && (
            request.auth.uid == resource.data.authorId
            || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
          );
        allow delete: if request.auth != null && (
          get(/databases/$(database)/documents/complaints/$(complaintId)).data.status == 'open'
          && get(/databases/$(database)/documents/complaints/$(complaintId)).data.isDeleted != true
          && (
            request.auth.uid == resource.data.authorId
            || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
          )
        );
      }
    }

    // Notifications collection
    match /notifications/{notificationId} {
      allow create: if request.auth != null
        && request.resource.data.actorId == request.auth.uid
        && request.resource.data.recipientId is string
        && request.resource.data.complaintId is string
        && request.resource.data.message is string
        && request.resource.data.isRead == false;

      allow read: if request.auth != null && resource.data.recipientId == request.auth.uid;

      allow update: if request.auth != null
        && resource.data.recipientId == request.auth.uid
        && request.resource.data.recipientId == resource.data.recipientId
        && request.resource.data.actorId == resource.data.actorId
        && request.resource.data.complaintId == resource.data.complaintId
        && request.resource.data.message == resource.data.message
        && request.resource.data.isRead is bool;

      allow delete: if request.auth != null && resource.data.recipientId == request.auth.uid;
    }

    // Fallback: deny everything else by default.
    match /{document=**} {
      allow read: if false;
      allow write: if false;
    }
  }
}
